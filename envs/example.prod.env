# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=CHANGE_ME__generate_with__openssl_rand_hex_32
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db (Postgres — prod compose와 정합. 운영은 DB 포트 미노출·ROOT 비번 불필요)
DB_HOST=postgres
DB_PORT=5432
DB_USER=ckduser
DB_PASSWORD=CHANGE_ME__db_password
DB_NAME=ckd_challenge

# 이메일: 운영은 데모 코드 응답 노출 방지를 위해 production 필수 (config가 prod+demo면 부팅 실패)
EMAIL_MODE=production

# redis
REDIS_PORT=6379

# RAG — OpenAI (배포 모델 정책: 4o/large — 차원 3072, collection 재구축 필요)
OPENAI_API_KEY=sk-your-prod-openai-key
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# RAG — Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=medical_kb_prod

# RAG — Langfuse (배포: self-host 내부 네트워크)
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-prod-key
LANGFUSE_SECRET_KEY=sk-lf-prod-key
