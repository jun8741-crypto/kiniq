# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=CHANGE_ME__generate_with__openssl_rand_hex_32
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# redis (RAG 챗봇 작업 큐 — docker 내부 실행 시 compose가 REDIS_HOST=redis로 override)
REDIS_HOST=localhost
REDIS_PORT=6379

# db
DB_HOST=localhost
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=ozcoding
DB_PASSWORD=CHANGE_ME__db_password
DB_ROOT_PASSWORD=CHANGE_ME__db_root_password
DB_NAME=ai_health

# RAG — OpenAI (개발 모델 정책: mini/small)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG — Qdrant (docker 실행 시 QDRANT_HOST=qdrant, 로컬 직접 실행 시 localhost)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=medical_kb_dev

# RAG — Langfuse (별도 docker-compose.langfuse.yml 기동 후 발급한 키 입력)
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key

# 이메일 발송 (REQ-AUTH-003 회원가입 인증 + 비밀번호 재설정)
# EMAIL_MODE: demo (시연·기본값) | gmail (Gmail SMTP + demo fallback) | production (Resend)
EMAIL_MODE=demo
EMAIL_FROM="CKD Care <onboarding@resend.dev>"
# Gmail SMTP (EMAIL_MODE=gmail 일 때 사용)
# 1) 본인 Google 계정 → 보안 → 2단계 인증 활성화
# 2) https://myaccount.google.com/apppasswords 에서 16자리 앱 비밀번호 발급
# 3) 아래에 입력 (절대 .env 커밋 X)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# Resend (EMAIL_MODE=production 일 때 사용)
RESEND_API_KEY=
