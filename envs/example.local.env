OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG — Qdrant (docker 실행 시 QDRANT_HOST=qdrant, 로컬 직접 실행 시 localhost)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=medical_kb_dev

# RAG — Langfuse (별도 docker-compose.langfuse.yml 기동 후 발급한 키 입력)
