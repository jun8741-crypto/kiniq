# Phase 1 PoC 환경 변수 — 복사: cp .env.example .env

# OpenAI API 키 (platform.openai.com → API keys)
OPENAI_API_KEY=sk-proj-...

# ─── 모델 정책 ([[project_api_model_policy]] 2026-05-20) ─────────────────────
# 개발 기간: gpt-4o-mini / text-embedding-3-small  ← 본 PoC (코드에 하드코딩)
# 배포 기간: gpt-4o      / text-embedding-3-large (3072d)
# ⚠️ Embedding 변경 시 Qdrant collection 재구축 필수 (차원 1536→3072)
# ⚠️ 배포 단계에서는 환경별 collection 분리: medical_kb_dev / medical_kb_prod
# ────────────────────────────────────────────────────────────────────────────

# KDIGO PDF 경로 (상대경로 또는 절대경로)
# 다운로드: https://kdigo.org/guidelines/ckd-evaluation-and-management/
# 전체 PDF 사용 시 파일명만 맞추거나, 본 값을 수정
KDIGO_PDF_PATH=./data/kdigo_ch5_diet.pdf

# Qdrant 로컬 캐시 경로 (인덱싱 결과 영속화, 재실행 시 비용·시간 절약)
# 삭제하면 다음 실행 시 재인덱싱됨. 또는 `python poc_rag.py --reindex`로 강제 재구축
QDRANT_LOCAL_PATH=./qdrant_local
